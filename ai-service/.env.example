# CivicShield AI Service Configuration Example
# Copy this to .env and update values as needed

# Environment
FASTAPI_ENV=development
LOG_LEVEL=info

# Server Configuration
HOST=0.0.0.0
PORT=5000

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# Model Configuration
VISION_MODEL=ViT-B-32
PRETRAINED=openai

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000,http://localhost:5173

# MongoDB (for future caching/logging)
MONGODB_URI=mongodb://localhost:27017/civicshield-ai

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=3600

# Hardware Configuration
USE_GPU=true
USE_MOCK_CLASSIFICATION=false

# Backend Service URL
CIVICSHIELD_BACKEND_URL=http://localhost:8080
